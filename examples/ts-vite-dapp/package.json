{
  "name": "biolerplate-template",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "test": "pnpm exec aptos-workspace test",
    "test:ci": "pnpm exec aptos-workspace test --timeout 300000",
    "test:mocha": "env TS_NODE_PROJECT=\"tsconfig.testing.json\" mocha --require ts-node/register 'tests/**/*.ts'",
    "build": "tsc && vite build",
    "lint": "biome lint .",
    "preview": "vite preview",
    "fmt": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^5.2.1",
    "@aptos-labs/wallet-adapter-react": "^3.5.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.2.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-environment": "^1.1.3"
  },
  "devDependencies": {
    "@aptos-labs/workspace": "file:../../workspace",
    "@biomejs/biome": "^2.0.0",
    "@types/chai": "4",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "chai": "4",
    "dotenv": "16.3.1",
    "mocha": "^10.8.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "ts-node": "latest",
    "typescript": "^5.2.2",
    "vite": "^6.4.2",
    "vite-plugin-notifier": "^0.1.5"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "7.0.5",
      "esbuild": "0.25.0"
    }
  }
}
