{
  "name": "biolerplate-template",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "ts-node index.ts",
    "test": "pnpm exec aptos-workspace test",
    "test:ci": "pnpm exec aptos-workspace test --timeout 300000",
    "build": "tsc",
    "lint": "biome lint .",
    "fmt": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^5.2.1",
    "@thalalabs/surf": "^1.7.3"
  },
  "devDependencies": {
    "@aptos-labs/workspace": "file:../../workspace",
    "@biomejs/biome": "^2.0.0",
    "@types/chai": "4",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.14",
    "chai": "4",
    "dotenv": "16.3.1",
    "ts-node": "10.9.1",
    "typescript": "^5.2.2"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.16.0"
    }
  }
}
